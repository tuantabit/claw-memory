{
  "name": "claw-memory",
  "version": "0.3.0",
  "description": "Verified memory for AI agents - detect lies, prevent forgetting",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "ai-agent",
    "claim-verification",
    "trust-score",
    "llm",
    "memory",
    "knowledge-graph",
    "vector-store",
    "temporal"
  ],
  "scripts": {
    "build": "tsc && cp openclaw.plugin.json dist/",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "memory-core": "github:tuantabit/memory-core",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuantabit/claw-memory.git"
  },
  "license": "MIT",
  "author": "OpenClaw Team",
  "engines": {
    "node": ">=22.5.0"
  }
}
