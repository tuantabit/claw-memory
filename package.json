{
  "name": "@openclaw/veridic-claw",
  "version": "0.2.0",
  "description": "Claim verification for AI agents - detect when agents lie about their actions",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "ai-agent",
    "claim-verification",
    "trust-score",
    "llm",
    "memory",
    "knowledge-graph"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/openclaw/openclaw.git",
    "directory": "extensions/veridic-claw"
  },
  "license": "MIT",
  "author": "OpenClaw Team"
}
