{
  "id": "claw-memory",
  "name": "Claw Memory",
  "version": "0.5.0",
  "description": "Verified memory for AI agents - detect lies, prevent forgetting",
  "entry": "index.js",
  "uiHints": {
    "enabled": {
      "label": "Enabled",
      "help": "Enable or disable claim verification"
    },
    "autoVerify": {
      "label": "Auto Verify",
      "help": "Automatically verify claims after each agent response"
    },
    "enableLLM": {
      "label": "Enable LLM Extraction",
      "help": "Use LLM for enhanced claim extraction (requires API key)"
    },
    "trustWarningThreshold": {
      "label": "Warning Threshold",
      "help": "Trust score below this triggers a warning (0-100)"
    },
    "trustBlockThreshold": {
      "label": "Block Threshold",
      "help": "Trust score below this blocks the agent (0-100)"
    },
    "dbPath": {
      "label": "Database Path",
      "help": "Path to SQLite database (default: ~/.openclaw/claw-memory.db)"
    },
    "retryEnabled": {
      "label": "Auto Retry",
      "help": "Automatically retry contradicted claims"
    },
    "retryMaxRetries": {
      "label": "Max Retries",
      "help": "Maximum retry attempts for contradicted claims (default: 2)"
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean",
        "default": true
      },
      "autoVerify": {
        "type": "boolean",
        "default": true
      },
      "enableLLM": {
        "type": "boolean",
        "default": false
      },
      "trustWarningThreshold": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100,
        "default": 70
      },
      "trustBlockThreshold": {
        "type": "integer",
        "minimum": 0,
        "maximum": 100,
        "default": 30
      },
      "dbPath": {
        "type": "string"
      },
      "retry": {
        "type": "object",
        "properties": {
          "enabled": {
            "type": "boolean",
            "default": true
          },
          "maxRetries": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5,
            "default": 2
          },
          "notifyUser": {
            "type": "boolean",
            "default": true
          }
        }
      }
    }
  }
}
